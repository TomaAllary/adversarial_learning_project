            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Animate PPO",
            "type": "debugpy",
            "request": "launch",
            "program": "./animate.py",
            "args": ["ppo", "--run", "runs/ppo_2", "--mode", "vs_scripted", "--fps", "3", "--episodes", "5"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Animate RNaD",
            "type": "debugpy",
            "request": "launch",
            "program": "./animate.py",
            "args": ["rnad", "--run", "runs/rnad_5", "--mode", "vs_scripted", "--fps", "3", "--episodes", "5"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Train RNaD + Exploiter",
            "type": "debugpy",
            "request": "launch",
