{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Train PPO",
            "type": "debugpy",
            "request": "launch",
            "program": "./train.py",
            "args": ["ppo", "--device", "cpu", "--total-steps", "50_000_000", "--n-envs", "8", "--opponent", "scripted", "--device", "cuda"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Train RNaD",
            "type": "debugpy",
            "request": "launch",
            "program": "./train.py",
            "args": ["rnad", "--total-steps", "2_000_000", "--device", "cuda"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Animate PPO",
            "type": "debugpy",
            "request": "launch",
            "program": "./animate.py",
            "args": ["ppo", "--run", "runs/ppo_2", "--mode", "vs_scripted", "--fps", "3", "--episodes", "5"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Animate RNaD",
            "type": "debugpy",
            "request": "launch",
            "program": "./animate.py",
            "args": ["rnad", "--run", "runs/rnad_5", "--mode", "vs_scripted", "--fps", "3", "--episodes", "5"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Train RNaD + Exploiter",
            "type": "debugpy",
            "request": "launch",
            "program": "./league_training.py",
            "args": [
                "--total-main-steps", "200_000_000", 
                "--exploiter-interval", "1000", 
                "--exploiter-max-steps", "1_000_000", 
                "--exploiter-weight", "0.3", 
                "--rnad-weight", "0.7", 
                "--run-dir", "runs/league_30pc_exploit",
                "--device", "cuda"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Train Exploiter",
            "type": "debugpy",
            "request": "launch",
            "program": "./minimax_exploiter.py",
            "args": [
                "exploiter", 
                "--main-checkpoint", 
                "runs/rnad_5/checkpoints/model_step_0004000.pt", 
                "--total-exploiter-steps", "1_000_000",
                "--run-name", "exploiter_rnad_400"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Evaluate model",
            "type": "debugpy",
            "request": "launch",
            "program": "./evaluate_checkpoints.py",
            "args": [
                "--run-dir", "runs/rnad_1", 
                "--out", "runs/rnad_1/eval_results_additional_exploiters.json", 
                "--episodes", "200", 
                "--device", "cpu", 
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Plot win-rate",
            "type": "debugpy",
            "request": "launch",
            "program": "./plotting/plot_winrate.py",
            "args": [
                "runs/evals/league_0pc_eval_results.json", 
                "--title", "RNaD",
                "--ratio", "1:1", 
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Plot exploiters",
            "type": "debugpy",
            "request": "launch",
            "program": "./plotting/plot_exploiter_curves.py",
            "args": [
                "--title", "PPO Exploiters Training for Different Checkpoints",
                "--ratio", "2:1", 
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
    ]
}